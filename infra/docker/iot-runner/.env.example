# Copy to .env and customise — .env is gitignored.
#
# THING_NAME: IoT Thing name; must match --thing-name used on the laptop.
THING_NAME=hw-pi-001

# AWS_REGION: Region for DescribeEndpoint fallback (default already us-west-2).
# AWS_REGION=us-west-2

# SBC_UID: UID of the Pi host user running docker compose.
# Run `id -u` on the Pi to find yours.  Must match the UID that owns
# ~/iot-data so the container can read the 0600 private key.
# SBC_UID=1000

# IOT_DATA_DIR: Host path mounted at /data/aws-iot inside the container.
# Defaults to $HOME/iot-data.  Change if you placed the bundle elsewhere.
# IOT_DATA_DIR=/home/hz42/iot-data
