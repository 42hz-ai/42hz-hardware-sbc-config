# SBCC optional shell exports across devcontainer rebuilds.
#
# Copy to env.local alongside this file; env.local is gitignored.
# Sources when your zsh login sees a cwd inside this repo (`git rev-parse`).
#
# Examples (uncomment):
# export ANTHROPIC_API_KEY=
# export SBC_IOT_FETCH_OUT_DIR=aws-iot-bundles/hw-devcontainer-001
