# ~/.aws/config example for the 42hz-hardware-sbc-config IoT hello-world stack.
#
# Copy to ~/.aws/config (or merge into an existing file).
# Replace <...> placeholders with real values from the SSO portal.
#
# SSO setup:        ../iotea-infrastructure-identity-center/docs/IDCTR-INFRA-0002-aws-identity-center-cdk.md
# Workload pattern: ../iotea-infrastructure-identity-center/docs/IDCTR-INFRA-0003-workload-cdk-pattern.md
# Operator runbook: docs/SBCC-INFRA-0001-iot-hello-world-cdk.md

[sso-session iotea]
sso_start_url = <SSO portal URL from IDCTR-INFRA-0002>
sso_region = us-west-2
sso_registration_scopes = sso:account:access

[profile spikes-sitewise]
sso_session = iotea
sso_account_id = <iotea-workloads-spikes-sitewise account id from SSO portal>
sso_role_name = AdministratorAccess
region = us-west-2
output = json
